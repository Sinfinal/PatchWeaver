# Python cache and bytecode
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
.venv/
venv/
env/

# Test and tooling cache
.pytest_cache/
.pytest_tmp/
pytest-cache-files-*/
pytest-of-*/
tmp_pytest*/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Build artifacts. The checked-in container definitions live under build/.
build/lib/
build/bdist.*/
build/temp.*/
dist/
*.egg-info/
web/node_modules/
web/dist/
*.tsbuildinfo

# IDE and editor files
.idea/
.vscode/

# Local secrets
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# Runtime data
data/*.db
data/logs/
data/manifests/*
!data/manifests/.gitkeep
!data/manifests/*.template.json
*.log

# Local scratch files created by agents or manual experiments
tmp/

# Generated workspaces and caches

!workspaces/.gitkeep
data/cache/*
!data/cache/.gitkeep
data/traces/*
!data/traces/.gitkeep
